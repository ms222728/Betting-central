# Copy this file to .env for local runs, or paste these as environment
# variables in your hosting dashboard (Railway/Render). Never commit .env.

# Required. Get a key at https://the-odds-api.com after signing up.
ODDS_API_KEY=

# Optional. Railway/Render set PORT automatically — leave unset in production.
PORT=3000

# Optional. Milliseconds between odds refreshes. Default 45000 (45s).
# Lower = fresher odds but burns through your Odds API monthly quota faster
# (5 leagues polled every cycle = 5 requests/cycle).
ODDS_POLL_INTERVAL_MS=45000

# Optional. The Odds API region(s) to pull bookmakers from, comma-separated.
# "us" covers FanDuel, DraftKings, BetMGM, Caesars, and other US books, and
# is what the "sharp" consensus is computed across. Default: us
ODDS_REGIONS=us

# Optional. CORS origin allowed to call this API from a browser. Default "*"
# (any origin). Set to your dashboard's exact origin to lock it down, e.g.
# https://your-dashboard.example.com
ALLOWED_ORIGIN=*
